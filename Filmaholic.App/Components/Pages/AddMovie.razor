@page "/movies/add"
@inject MovieService MovieService
@inject NavigationManager Nav

@using Filmaholic.Shared.Dtos

<h3>Add Movie</h3>

<EditForm Model="@movie" OnSubmit="SaveMovie">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="form-group">
        <label>Title:</label>
        <InputText @bind-Value="movie.Title" class="form-control" />
    </div>

        <div class="form-group">
        <label>AgeGroup:</label>
        <InputText @bind-Value="movie.AgeGroup" class="form-control" />
    </div>

        <div class="form-group">
        <label>Genre:</label>
        <InputText @bind-Value="movie.Genre" class="form-control" />
    </div>

    <div class="form-group">
        <label>Year:</label>
        <InputNumber @bind-Value="movie.Year" class="form-control" />
    </div>

    <div class="form-group">
        <label>Description:</label>
        <InputTextArea @bind-Value="movie.Description"
                       class="form-control"
                       rows="4" />
    </div>

    <button type="submit" class="btn btn-primary">
        Save
    </button>

    <button type="button"
            class="btn btn-secondary"
            @onclick="Cancel">
        Cancel
    </button>

</EditForm>

@if (submitted)
{
    <div class="alert alert-success mt-3">
        Movie saved!
    </div>
}

@code {

    private CreateMovieDto movie = new CreateMovieDto();

    private bool submitted;

    private async Task SaveMovie()
    {
        await MovieService.AddMovieAsync(movie);
        submitted = true;
        Nav.NavigateTo("/movies");
    }

    private void Cancel()
    {
        Nav.NavigateTo("/movies");
    }
}